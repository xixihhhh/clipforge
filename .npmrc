# pnpm: flat, symlink-free node_modules (npm-style hoisting).
# Rationale: Next.js output:"standalone" reproduces pnpm .pnpm symlinks in the bundle;
# on Windows the packaging copy (robocopy) follows those links and flattens next to the
# top level, detaching it from its .pnpm peers -> "Cannot find module @swc/helpers" (issue #10).
# A hoisted layout has no symlinks, so the standalone copies cleanly on every OS.
node-linker=hoisted
